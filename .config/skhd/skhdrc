#!/usr/bin/env sh

############
# Layer - Most used actions
# Keys: ctrl / ctrl + shift
# ---------------------------
# Updated for AeroSpace instead of yabai
# 1. Jumping between windows (Mac, Tmux, Vim)
# 2. Swapping windows
# 3. Opening up applications
# 4. Making a window fullscreen
# 5. Layout management
#
###########

# Media Controls with Ctrl + Function Keys (F1-F12)
# Brightness
# Brightness down
ctrl - f1 : skhd -k "0x91"
# Brightness up
ctrl - f2 : skhd -k "0x90"
# Media playback
# Previous Track
ctrl - f7 : osascript -e 'tell application "Music" to previous track'
# Play/Pause
ctrl - f8 : osascript -e 'tell application "Music" to playpause'
# Next Track
ctrl - f9 : osascript -e 'tell application "Music" to next track'
# Volume
# Toggle Mute
ctrl - f10 : ~/.local/bin/mediakey mute
# Volume Down
ctrl - f11 : ~/.local/bin/mediakey voldown
# Volume Up
ctrl - f12 : ~/.local/bin/mediakey volup

# Toggle between layouts (simplified for AeroSpace) - removed, use workspace mode instead

# Changing Window Focus with Ctrl+hjkl - Smart navigation for terminals
# focus previous window (dfs)
ctrl - h [
* : aerospace focus dfs-prev
"kitty" ~
"Alacritty" ~
]
# focus down
ctrl - j [
* : aerospace focus down
"kitty" ~
"Alacritty" ~
]
# focus up
ctrl - k [
* : aerospace focus up
"kitty" ~
"Alacritty" ~
]
# focus next window (dfs)
ctrl - l [
* : aerospace focus dfs-next
"kitty" ~
"Alacritty" ~
]

# Float center toggle (replaces fullscreen)
ctrl - f : ~/.config/aerospace/toggle-floating-centered.sh

# Workspaces
# switch to workspace q
cmd + ctrl - q : aerospace workspace q
# switch to workspace w
cmd + ctrl - w : aerospace workspace w
# switch to workspace f
cmd + ctrl - f : aerospace workspace f
# switch to workspace p
cmd + ctrl - p : aerospace workspace p
# switch to workspace g
cmd + ctrl - g : aerospace workspace g

# Mode declarations (removed @ to avoid capturing all keypresses)
:: default : echo "default" >/tmp/skhd_mode && open -g swiftbar://refreshplugin?name=skhd-mode
:: service : echo "service" >/tmp/skhd_mode && open -g swiftbar://refreshplugin?name=skhd-mode
:: workspace : echo "workspace" >/tmp/skhd_mode && open -g swiftbar://refreshplugin?name=skhd-mode
:: launcher : echo "launcher" >/tmp/skhd_mode && open -g swiftbar://refreshplugin?name=skhd-mode
:: writing : echo "writing" >/tmp/skhd_mode && open -g swiftbar://refreshplugin?name=skhd-mode
:: break @ : echo "break" >/tmp/skhd_mode && open -g swiftbar://refreshplugin?name=skhd-mode

# Mode switching shortcuts
# [ hyper+b ] enter break mode
shift + ctrl + alt + cmd - b ; break
# [ hyper+n ] return to default mode
shift + ctrl + alt + cmd - n ; default
# [ hyper+s ] enter service mode
shift + ctrl + alt + cmd - s ; service
# cmd+space - enter launcher mode
cmd - space ; launcher
# open searchable keybindings popup
shift + cmd - k : open "raycast://extensions/dwain/skhd-keybindings/index"

# Break mode bindings - only escape works, starts new work session
# start new 40min work session
break < escape : pomodoro start 40 & skhd -k "return"
# return to default mode
break < return ; default

# Service mode bindings - only work when in service mode
# return to default mode
service < escape ; default
# reload AeroSpace config
service < r : aerospace reload-config

# Workspace mode bindings - layout changes and window management
# return to default mode
workspace < escape ; default

# ============ LAYOUT CHANGES ============
# Simple mental model:
#   h = horizontal (side by side)  |W1|W2|W3|
#   v = vertical (stacked)         W1/W2/W3
#   a = accordion (tabs, one visible)
#   f = floating (free drag)
#   space = toggle current window float/tile

# Tiles: windows split evenly
# horizontal tiles (side by side)
workspace < h : aerospace flatten-workspace-tree && aerospace layout h_tiles ; skhd -k "escape"
# vertical tiles (stacked)
workspace < v : aerospace flatten-workspace-tree && aerospace layout v_tiles ; skhd -k "escape"
# accordion (tabs)
workspace < a : aerospace flatten-workspace-tree && aerospace layout h_accordion ; skhd -k "escape"
# vertical accordion (tabs)
workspace < shift - a : aerospace flatten-workspace-tree && aerospace layout v_accordion ; skhd -k "escape"
# toggle focused window float + center at 60% width, full height
workspace < space : ~/.config/aerospace/toggle-floating-centered.sh ; skhd -k "escape"
# toggle focused window float + center at 60% width, full height
workspace < t : ~/.config/aerospace/toggle-floating-centered.sh ; skhd -k "escape"

# Reset: flatten everything and go back to default tiles
# reset layout (flatten + tiles)
workspace < r : aerospace list-windows --workspace focused --format '%{window-id}' | xargs -I {} aerospace layout --window-id {} tiling && aerospace flatten-workspace-tree && aerospace layout h_tiles ; skhd -k "escape"

# ============ RESIZE ============
# [ - ] shrink window by 50
workspace < 0x1B : aerospace resize smart -50
# [ = ] grow window by 50
workspace < 0x18 : aerospace resize smart +50
# [ shift - ] shrink fast by 100
workspace < shift - 0x1B : aerospace resize smart -100
# [ shift = ] grow fast by 100
workspace < shift - 0x18 : aerospace resize smart +100

# ============ MOVE WINDOWS ============
# move window left
workspace < shift - h : aerospace move left ; skhd -k "escape"
# move window down
workspace < shift - j : aerospace move down ; skhd -k "escape"
# move window up
workspace < shift - k : aerospace move up ; skhd -k "escape"
# move window right
workspace < shift - l : aerospace move right ; skhd -k "escape"
# join with left
workspace < alt - h : aerospace join-with left ; skhd -k "escape"
# join with down
workspace < alt - j : aerospace join-with down ; skhd -k "escape"
# join with up
workspace < alt - k : aerospace join-with up ; skhd -k "escape"
# join with right
workspace < alt - l : aerospace join-with right ; skhd -k "escape"
# switch to workspace q
workspace < q : aerospace workspace q ; skhd -k "escape"
# switch to workspace w
workspace < w : aerospace workspace w ; skhd -k "escape"
# switch to workspace f
workspace < f : aerospace workspace f ; skhd -k "escape"
# switch to workspace p
workspace < p : aerospace workspace p ; skhd -k "escape"
# switch to workspace g
workspace < g : aerospace workspace g ; skhd -k "escape"
# move window to workspace q
workspace < shift - q : aerospace move-node-to-workspace q && aerospace workspace q ; skhd -k "escape"
# move window to workspace w
workspace < shift - w : aerospace move-node-to-workspace w && aerospace workspace w ; skhd -k "escape"
# move window to workspace f
workspace < shift - f : aerospace move-node-to-workspace f && aerospace workspace f ; skhd -k "escape"
# move window to workspace p
workspace < shift - p : aerospace move-node-to-workspace p && aerospace workspace p ; skhd -k "escape"
# move window to workspace g
workspace < shift - g : aerospace move-node-to-workspace g && aerospace workspace g ; skhd -k "escape"

# Launcher mode bindings - quick app launching
# return to default mode
launcher < escape ; default
# return to default mode
launcher < return ; default
# Raycast quicklinks
launcher < l : open "raycast://extensions/raycast/raycast/search-quicklinks" && skhd -k "return"
# add new quicklink
launcher < shift - l : open "raycast://extensions/raycast/raycast/create-quicklink" && skhd -k "return"
# switch to workspace mode
launcher < w ; workspace
# switch to writing mode
launcher < i ; writing
# [ ] ] next workspace
launcher <0x1E : aerospace workspace --wrap-around next && skhd -k "return"
# [ [ ] previous workspace
launcher <0x21 : aerospace workspace --wrap-around prev && skhd -k "return"
# [ \ ] switch to previous window
launcher <0x2A : aerospace focus-back-and-forth && skhd -k "return"
# open Kitty + AI session
launcher <a : osascript -e 'tell application "kitty" to activate' && tmux select-window -t $(tmux list-clients -F "#{client_activity} #{session_name}" | sort -rn | head -1 | cut -d' ' -f2):AI && skhd -k "return"
# open Obsidian
launcher <o : open -a "Obsidian" && skhd -k "return"
# open Raycast
launcher <r : open -a "Raycast" && skhd -k "return"
# open Safari (workspace q)
launcher <b : /bin/sh -c 'win=$(aerospace list-windows --workspace q --app-id com.apple.Safari --format "%{window-id}" | head -1) && [ -n "$win" ] && aerospace focus --window-id $win || aerospace workspace q && open -a "Safari"' && skhd -k "return"
# open Safari (workspace g)
launcher <s : /bin/sh -c 'win=$(aerospace list-windows --workspace g --app-id com.apple.Safari --format "%{window-id}" | head -1) && [ -n "$win" ] && aerospace focus --window-id $win || aerospace workspace g && open -a "Safari"' && skhd -k "return"
# open Mail
launcher <m : open -a "Mail" && skhd -k "return"
# start 40min pomodoro
launcher <n : pomodoro start 40 && skhd -k "return"
# open System Settings
launcher <d : open -a "System Settings" && skhd -k "return"
# open temporary Kitty
launcher <k : /usr/bin/osascript -e 'tell application "kitty" to activate' || open /Applications/kitty.app -n --args --single-instance --instance-group "QuickFullKitty" && skhd -k "return"
# open nvim
launcher <v : osascript -e 'tell application "kitty" to activate' && /bin/sh -c 'SESSION=$(tmux list-clients -F "#{client_activity} #{session_name}" | sort -rn | head -1 | cut -d" " -f2) && WINDOW=$(tmux list-windows -t $SESSION -F "#{window_index} #{pane_current_command}" | grep -E "nvim|vim" | head -1 | cut -d" " -f1) && tmux select-window -t $SESSION:$WINDOW' && skhd -k "return"
# open terminal
launcher <t : osascript -e 'tell application "kitty" to activate' && /bin/sh -c 'SESSION=$(tmux list-clients -F "#{client_activity} #{session_name}" | sort -rn | head -1 | cut -d" " -f2) && WINDOW=$(tmux list-windows -t $SESSION -F "#{window_index} #{pane_current_command}" | grep -E "zsh|bash" | head -1 | cut -d" " -f1) && tmux select-window -t $SESSION:$WINDOW' && skhd -k "return"
# open Calendar
launcher <c : open -a "Calendar" && skhd -k "return"
# toggle keyboard layout (ABC/Colemak)
launcher <z : skhd -k "return"

# Writing mode bindings - distraction-free writing mode
# return to default mode
writing < escape ; default
# switch to launcher mode
writing < cmd - space ; launcher
# switch to break mode
writing < shift + ctrl + alt + cmd - b ; break
