#!/usr/bin/env sh

############
# Flat keybindings - single default layer, no modes.
# Each action group lives on its own modifier combo so nothing
# ever needs a "mode" to disambiguate keys:
#
#   ctrl            -> window focus, float toggle, media keys
#   cmd + ctrl       -> workspace switch
#   ctrl + shift     -> move window / move window to workspace
#   ctrl + alt       -> join window with neighbor
#   cmd + shift      -> layout changes
#   cmd + alt        -> app launcher shortcuts + workspace nav
############

# ============ MEDIA (ctrl + function keys) ============
# Brightness down
ctrl - f1 : skhd -k "0x91"
# Brightness up
ctrl - f2 : skhd -k "0x90"
# Previous Track
ctrl - f7 : osascript -e 'tell application "Music" to previous track'
# Play/Pause
ctrl - f8 : osascript -e 'tell application "Music" to playpause'
# Next Track
ctrl - f9 : osascript -e 'tell application "Music" to next track'
# Toggle Mute
ctrl - f10 : ~/.local/bin/mediakey mute
# Volume Down
ctrl - f11 : ~/.local/bin/mediakey voldown
# Volume Up
ctrl - f12 : ~/.local/bin/mediakey volup

# ============ WINDOW FOCUS (ctrl) ============
# focus previous window (dfs)
ctrl - h [
* : aerospace focus dfs-prev
"kitty" ~
"Alacritty" ~
]

# focus down
ctrl - j [
* : aerospace focus down
"kitty" ~
"Alacritty" ~
]

# focus up
ctrl - k [
* : aerospace focus up
"kitty" ~
"Alacritty" ~
]

# focus next window (dfs)
ctrl - l [
* : aerospace focus dfs-next
"kitty" ~
"Alacritty" ~
]

# toggle float + center current window
ctrl - f : ~/.config/aerospace/toggle-floating-centered.sh

# open searchable keybindings popup
shift + cmd - k : ~/.local/bin/skhd-search

# ============ WORKSPACES (cmd + ctrl) ============
# switch to workspace q
cmd + ctrl - q : aerospace workspace q
# switch to workspace w
cmd + ctrl - w : aerospace workspace w
# switch to workspace f
cmd + ctrl - f : aerospace workspace f
# switch to workspace p
cmd + ctrl - p : aerospace workspace p
# switch to workspace g
cmd + ctrl - g : aerospace workspace g

# ============ MOVE WINDOWS (ctrl + shift) ============
# move window left
ctrl + shift - h : aerospace move left
# move window down
ctrl + shift - j : aerospace move down
# move window up
ctrl + shift - k : aerospace move up
# move window right
ctrl + shift - l : aerospace move right

# move window to workspace q
ctrl + shift - q : aerospace move-node-to-workspace q && aerospace workspace q
# move window to workspace w
ctrl + shift - w : aerospace move-node-to-workspace w && aerospace workspace w
# move window to workspace f
ctrl + shift - f : aerospace move-node-to-workspace f && aerospace workspace f
# move window to workspace p
ctrl + shift - p : aerospace move-node-to-workspace p && aerospace workspace p
# move window to workspace g
ctrl + shift - g : aerospace move-node-to-workspace g && aerospace workspace g

# ============ JOIN WINDOWS (ctrl + alt) ============
# join with left
ctrl + alt - h : aerospace join-with left
# join with down
ctrl + alt - j : aerospace join-with down
# join with up
ctrl + alt - k : aerospace join-with up
# join with right
ctrl + alt - l : aerospace join-with right

# ============ LAYOUT CHANGES (cmd + shift) ============
# horizontal tiles (side by side)
cmd + shift - h : aerospace flatten-workspace-tree && aerospace layout h_tiles
# vertical tiles (stacked)
cmd + shift - v : aerospace flatten-workspace-tree && aerospace layout v_tiles
# accordion (tabs)
cmd + shift - a : aerospace flatten-workspace-tree && aerospace layout h_accordion
# vertical accordion (stacked tabs)
cmd + shift - s : aerospace flatten-workspace-tree && aerospace layout v_accordion
# reset layout (flatten + tiles)
cmd + shift - r : aerospace list-windows --workspace focused --format '%{window-id}' | xargs -I {} aerospace layout --window-id {} tiling && aerospace flatten-workspace-tree && aerospace layout h_tiles

# ============ APP LAUNCHER (cmd + alt) ============
# open Kitty + AI session
cmd + alt - a : osascript -e 'tell application "kitty" to activate' && tmux select-window -t $(tmux list-clients -F "#{client_activity} #{session_name}" | sort -rn | head -1 | cut -d' ' -f2):AI
# open Obsidian
cmd + alt - o : open -a "Obsidian"
# open Raycast
cmd + alt - r : open -a "Raycast"
# open Safari (workspace q)
cmd + alt - b : /bin/sh -c 'win=$(aerospace list-windows --workspace q --app-id com.apple.Safari --format "%{window-id}" | head -1) && [ -n "$win" ] && aerospace focus --window-id $win || aerospace workspace q && open -a "Safari"'
# open Safari (workspace g)
cmd + alt - s : /bin/sh -c 'win=$(aerospace list-windows --workspace g --app-id com.apple.Safari --format "%{window-id}" | head -1) && [ -n "$win" ] && aerospace focus --window-id $win || aerospace workspace g && open -a "Safari"'
# open Mail
cmd + alt - m : open -a "Mail"
# open System Settings
cmd + alt - d : open -a "System Settings"
# open temporary Kitty
cmd + alt - k : /usr/bin/osascript -e 'tell application "kitty" to activate' || open /Applications/kitty.app -n --args --single-instance --instance-group "QuickFullKitty"
# open nvim
cmd + alt - v : osascript -e 'tell application "kitty" to activate' && /bin/sh -c 'SESSION=$(tmux list-clients -F "#{client_activity} #{session_name}" | sort -rn | head -1 | cut -d" " -f2) && WINDOW=$(tmux list-windows -t $SESSION -F "#{window_index} #{pane_current_command}" | grep -E "nvim|vim" | head -1 | cut -d" " -f1) && tmux select-window -t $SESSION:$WINDOW'
# open terminal
cmd + alt - t : osascript -e 'tell application "kitty" to activate' && /bin/sh -c 'SESSION=$(tmux list-clients -F "#{client_activity} #{session_name}" | sort -rn | head -1 | cut -d" " -f2) && WINDOW=$(tmux list-windows -t $SESSION -F "#{window_index} #{pane_current_command}" | grep -E "zsh|bash" | head -1 | cut -d" " -f1) && tmux select-window -t $SESSION:$WINDOW'
# open Calendar
cmd + alt - c : open -a "Calendar"
# next workspace
cmd + alt - 0x1E : aerospace workspace --wrap-around next
# previous workspace
cmd + alt - 0x21 : aerospace workspace --wrap-around prev
# switch to previous window
cmd + alt - 0x2A : aerospace focus-back-and-forth
