{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/deepseek-v4-flash-free",
  "instructions": ["~/.config/opencode/AGENTS.md", "AGENTS.md"],
  "plugin": [],
  "permission": {
    "*": {
      "*": "allow"
    }
  },
  "provider": {
    "opencode": {
      "whitelist": [
        "claude-haiku-4-5",
        "gpt-5.5",
        "claude-opus-4-5",
        "kimi-k2.6",
        "qwen3.6-plus",
        "deepseek-v4-flash-free"
      ]
    },
    "opencode-go": {
      "whitelist": [
        "kimi-k2.7-code",
        "deepseek-v4-pro",
        "minimax-m3"
      ]
    }
  },
  "agent": {
    "plan": {
      "mode": "primary",
      "model": "opencode/claude-opus-4-5",
      "description": "Deep reasoning for architecture, planning, and complex analysis. No code edits — thinking only.",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "build": {
      "mode": "primary",
      "model": "opencode-go/kimi-k2.7-code",
      "description": "Orchestrator that delegates all implementation work to @general subagents. Focuses on task decomposition, reviewing results, and user communication.",
      "permission": {
        "task": {
          "*": "allow",
          "general": "allow",
          "explore": "allow"
        }
      }
    },
    "general": {
      "mode": "subagent",
      "model": "opencode/kimi-k2.6",
      "description": "Worker agent for implementing features, writing code, running tests, and performing actual file edits. Invoked by build agent for all hands-on work.",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "task": "deny"
      }
    },
    "explore": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "description": "Read-only codebase researcher. Finds files, searches patterns, and answers questions about existing code. No edits.",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    }
  }
}
