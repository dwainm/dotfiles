#!/usr/bin/env bash

# j - CLI tool for managing project jobs (tasks, specs, bugs, ideas)
# Usage:
#   j [list] [folder]              List all jobs (or filter by folder)
#   j new <title>                  Create new task (default type)
#   j new --spec <title>           Create new spec
#   j new --bug <title>            Create new bug
#   j new --idea <title>           Create new idea
#   j active <name>                Move job to active
#   j done <name>                  Move job to done
#   j move <folder> <name>         Move job between folders

# Handle completion before git check (needs to work everywhere)
if [[ "$1" == "completion" ]]; then
    cat <<'EOF'
#compdef j

_j() {
    local -a commands
    commands=(
        'list:List all jobs'
        'new:Create new job'
        'active:Move job to active'
        'done:Move job to done'
        'promote:Promote idea to planned'
        'move:Move job between folders'
        'completion:Output shell completion script'
        'help:Show help message'
    )

    local -a folders
    folders=('planned' 'active' 'done' 'ideas')

    local -a types
    types=('--spec' '--bug' '--idea' '--task')

    _get_jobs() {
        local jobs_dir="jobs"
        if [[ -d "$jobs_dir" ]]; then
            find "$jobs_dir" -type f -name "*.md" 2>/dev/null | while read -r file; do
                basename "$file" .md | sed -E 's/^[0-9]{2}-[0-9]{2}-[0-9]{2}-//'
            done
        fi
    }

    _get_ideas() {
        local jobs_dir="jobs/ideas"
        if [[ -d "$jobs_dir" ]]; then
            find "$jobs_dir" -type f -name "*.md" 2>/dev/null | while read -r file; do
                basename "$file" .md | sed -E 's/^[0-9]{2}-[0-9]{2}-[0-9]{2}-//'
            done
        fi
    }

    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '1: :->command' \
        '*:: :->args'

    case $state in
        command)
            _describe 'command' commands
            ;;
        args)
            case $words[1] in
                list|ls)
                    if [[ $CURRENT -eq 2 ]]; then
                        _describe 'folder' folders
                    fi
                    ;;
                new)
                    if [[ $CURRENT -eq 2 ]]; then
                        _describe 'type' types
                    fi
                    ;;
                active|done)
                    if [[ $CURRENT -eq 2 ]]; then
                        local -a jobs
                        jobs=(${(f)"$(_get_jobs)"})
                        _describe 'job' jobs
                    fi
                    ;;
                promote)
                    if [[ $CURRENT -eq 2 ]]; then
                        local -a ideas
                        ideas=(${(f)"$(_get_ideas)"})
                        _describe 'idea' ideas
                    fi
                    ;;
                move|mv)
                    if [[ $CURRENT -eq 2 ]]; then
                        _describe 'folder' folders
                    elif [[ $CURRENT -eq 3 ]]; then
                        local -a jobs
                        jobs=(${(f)"$(_get_jobs)"})
                        _describe 'job' jobs
                    fi
                    ;;
            esac
            ;;
    esac
}

compdef _j j
EOF
    exit 0
fi

# Require git repo for all other commands
if ! git rev-parse --git-dir >/dev/null 2>&1; then
    echo "Error: Not in a git repository"
    exit 1
fi

JOBS_DIR="jobs"
FOLDERS=("planned" "active" "done" "ideas")
TYPES=("task" "spec" "bug" "idea")

# Ensure jobs directory structure exists
ensure_dirs() {
    for f in "${FOLDERS[@]}"; do
        mkdir -p "$JOBS_DIR/$f"
    done
}

# Get current date in dd-mm-yy format
get_date() {
    date +"%d-%m-%y"
}

# Find job file by name (without date prefix)
find_job() {
    local name="$1"
    find "$JOBS_DIR" -maxdepth 2 -type f \( -name "*-${name}.md" -o -name "${name}.md" \) 2>/dev/null | head -n 1
}

# Get type emoji based on folder
type_emoji() {
    case "$1" in
        ideas) echo "💡" ;;
        *) echo "✓" ;;
    esac
}

# Get type emoji for job creation
job_type_emoji() {
    case "$1" in
        spec) echo "📋" ;;
        bug) echo "🐛" ;;
        idea) echo "💡" ;;
        task|*) echo "✓" ;;
    esac
}

# List all jobs
list_jobs() {
    local filter_folder="$1"
    ensure_dirs

    # Validate filter folder if provided
    if [ -n "$filter_folder" ]; then
        local valid=0
        for f in "${FOLDERS[@]}"; do
            if [ "$f" = "$filter_folder" ]; then
                valid=1
                break
            fi
        done

        if [ $valid -eq 0 ]; then
            echo "Error: Invalid folder '$filter_folder'. Must be one of: ${FOLDERS[*]}"
            exit 1
        fi
    fi

    echo "Jobs"
    echo ""

    for folder in "${FOLDERS[@]}"; do
        # Skip folders that don't match filter
        if [ -n "$filter_folder" ] && [ "$folder" != "$filter_folder" ]; then
            continue
        fi

        local items=$(find "$JOBS_DIR/$folder" -maxdepth 1 -type f -name "*.md" 2>/dev/null | sort -r)
        local has_output=0
        local output=""
        local emoji=$(type_emoji "$folder")

        if [ -n "$items" ]; then
            while read -r item; do
                [ -z "$item" ] && continue
                local bname=$(basename "$item")
                bname="${bname%.md}"

                has_output=1

                # Extract date and name from filename
                if [[ $bname =~ ^([0-9]{2})-([0-9]{2})-([0-9]{2})-(.+)$ ]]; then
                    local day="${BASH_REMATCH[1]}"
                    local month="${BASH_REMATCH[2]}"
                    local year="${BASH_REMATCH[3]}"
                    local name="${BASH_REMATCH[4]}"

                    name=$(echo "$name" | sed 's/-/ /g' | awk '{for(i=1;i<=NF;i++) $i=toupper(substr($i,1,1)) tolower(substr($i,2))}1')

                    output+="  $emoji $name ($day/$month/$year)\n"
                else
                    output+="  $emoji $bname\n"
                fi
            done <<< "$items"

            if [ $has_output -eq 1 ]; then
                echo "[$folder]"
                printf "$output"
                echo ""
            fi
        fi
    done
}

# Create new job
new_job() {
    local type="task"
    local folder="planned"
    local title=""
    local open_editor=0

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --spec|-s) type="spec"; shift ;;
            --bug|-b) type="bug"; shift ;;
            --idea|-i) type="idea"; folder="ideas"; shift ;;
            --task|-t) type="task"; shift ;;
            --active|-a) folder="active"; shift ;;
            --edit|-e) open_editor=1; shift ;;
            *) title="$*"; break ;;
        esac
    done

    if [ -z "$title" ]; then
        echo "Error: Title required"
        echo "Usage: j new [--spec|--bug|--idea] [--active] [--edit] <title>"
        exit 1
    fi

    ensure_dirs

    local date=$(get_date)
    local slug=$(echo "$title" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//')
    local filename="$date-$slug.md"
    local filepath="$JOBS_DIR/$folder/$filename"

    if [ -f "$filepath" ]; then
        echo "Error: Job already exists: $filepath"
        exit 1
    fi

    # Generate content based on type
    case "$type" in
        spec)
            cat > "$filepath" <<EOF
---
type: spec
created: $(date +"%d %B %Y")
---

# $title

## Overview

## Requirements

## Implementation

## Testing

EOF
            ;;
        bug)
            cat > "$filepath" <<EOF
---
type: bug
created: $(date +"%d %B %Y")
---

# $title

## Description

## Steps to Reproduce

## Expected Behavior

EOF
            ;;
        idea)
            cat > "$filepath" <<EOF
---
type: idea
created: $(date +"%d %B %Y")
---

# $title

## Concept

EOF
            ;;
        task|*)
            cat > "$filepath" <<EOF
---
type: task
created: $(date +"%d %B %Y")
---

# $title

EOF
            ;;
    esac

    # Git add and commit
    git add "$filepath"
    git commit -m "Add $type: $title"

    local emoji=$(job_type_emoji "$type")
    echo "$emoji Created: $filepath"

    # Open in editor only if --edit flag passed
    if [ $open_editor -eq 1 ] && [ -n "$EDITOR" ]; then
        $EDITOR "$filepath"
    fi
}

# Check if we're in a git repo
is_git_repo() {
    git rev-parse --git-dir >/dev/null 2>&1
}

# Check if a file is tracked by git
is_git_tracked() {
    local file="$1"
    git ls-files --error-unmatch "$file" >/dev/null 2>&1
}

# Move job between folders
move_job() {
    local target_folder="$1"
    local name="$2"

    if [ -z "$target_folder" ] || [ -z "$name" ]; then
        echo "Error: Target folder and job name required"
        echo "Usage: j move <planned|active|done|ideas> <name>"
        exit 1
    fi

    # Validate target folder
    local valid=0
    for folder in "${FOLDERS[@]}"; do
        if [ "$folder" = "$target_folder" ]; then
            valid=1
            break
        fi
    done

    if [ $valid -eq 0 ]; then
        echo "Error: Invalid folder '$target_folder'. Must be one of: ${FOLDERS[*]}"
        exit 1
    fi

    # Find the job file
    local job_file=$(find_job "$name")

    if [ -z "$job_file" ]; then
        echo "Error: Job not found: $name"
        exit 1
    fi

    local filename=$(basename "$job_file")
    local new_path="$JOBS_DIR/$target_folder/$filename"

    if [ "$job_file" = "$new_path" ]; then
        echo "Job already in $target_folder: $filename"
        exit 0
    fi

    # Check if file is git-tracked and use git mv + commit
    if is_git_repo && is_git_tracked "$job_file"; then
        git mv "$job_file" "$new_path"
        git commit -m "Move job '$name' to $target_folder"
        echo "Moved to $target_folder: $filename (git committed)"
    else
        mv "$job_file" "$new_path"
        echo "Moved to $target_folder: $filename"
    fi
}

# Promote idea (moves to planned)
promote_idea() {
    local name="$1"

    if [ -z "$name" ]; then
        echo "Error: Idea name required"
        echo "Usage: j promote <name>"
        exit 1
    fi

    # Find the job file (should be in ideas folder)
    local job_file=$(find "$JOBS_DIR/ideas" -maxdepth 1 -type f \( -name "*-${name}.md" -o -name "${name}.md" \) 2>/dev/null | head -n 1)

    if [ -z "$job_file" ]; then
        echo "Error: Idea not found: $name"
        exit 1
    fi

    # Move to planned
    local filename=$(basename "$job_file")
    local new_path="$JOBS_DIR/planned/$filename"

    if is_git_tracked "$job_file"; then
        git mv "$job_file" "$new_path"
    else
        mv "$job_file" "$new_path"
    fi

    # Commit
    git add "$new_path"
    git commit -m "Promote idea '$name' to planned"

    echo "💡 Promoted to planned: $filename"
}

# Main command dispatcher
main() {
    local cmd="${1:-list}"

    case "$cmd" in
        list|ls|"")
            shift 2>/dev/null
            list_jobs "$1"
            ;;
        new|create|add)
            shift
            new_job "$@"
            ;;
        active)
            shift
            move_job "active" "$*"
            ;;
        done)
            shift
            move_job "done" "$*"
            ;;
        promote)
            shift
            promote_idea "$1"
            ;;
        move|mv)
            shift
            move_job "$1" "$2"
            ;;
        help|--help|-h)
            cat <<EOF
j - CLI tool for managing project jobs

Usage:
  j [list] [folder]              List all jobs (or filter by folder)
  j new <title>                  Create new task (default)
  j new --spec <title>           Create new spec
  j new --bug <title>            Create new bug
  j new --idea <title>           Create new idea
  j new --active <title>         Create and start immediately
  j new --edit <title>           Create and open in editor
  j active <name>                Move job to active
  j done <name>                  Move job to done
  j promote <name>               Promote idea to planned
  j move <folder> <name>         Move job between folders
  j completion                   Output shell completion script

Types: task (default), spec, bug, idea
Folders: planned (default), active, done, ideas
Files: jobs/{folder}/dd-mm-yy-name.md

Setup:
  Add to ~/.zshrc:  eval "\$(j completion)"

Examples:
  j                              # List all jobs
  j list planned                 # List only planned
  j list ideas                   # List only ideas
  j new "fix login"              # Create task
  j new --bug "crash on mobile"  # Create bug
  j new --spec "auth system"     # Create spec
  j new --idea "what if..."      # Capture idea (goes to ideas/)
  j new --active "quick fix"     # Create and start now
  j active "fix login"           # Start working
  j done "fix login"             # Mark complete
  j promote "what if"            # Move idea to planned
EOF
            ;;
        *)
            echo "Error: Unknown command '$cmd'"
            echo "Run 'j help' for usage"
            exit 1
            ;;
    esac
}

main "$@"
