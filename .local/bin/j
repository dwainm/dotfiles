#!/usr/bin/env bash

# j - CLI tool for managing project jobs (tasks, specs, bugs, ideas)
# Optimized: pure bash string ops, fast git check (~23ms vs ~300ms)

# Handle completion before git check (needs to work everywhere)
if [[ "$1" == "completion" ]]; then
    cat <<'EOF'
#compdef j

_j() {
    local -a commands
    commands=(
        'list:List all jobs'
        'new:Create new job'
        'active:Move job to active'
        'done:Move job to done'
        'promote:Promote idea to planned'
        'move:Move job between folders'
        'groups:List all groups'
        'group:Assign job to group'
        'ungroup:Remove job from group'
        'completion:Output shell completion script'
        'help:Show help message'
    )

    local -a folders
    folders=('planned' 'active' 'done' 'ideas')

    local -a types
    types=('--spec' '--bug' '--idea' '--task')

    _get_jobs() {
        local jobs_dir="jobs"
        if [[ -d "$jobs_dir" ]]; then
            for file in "$jobs_dir"/*/*.md; do
                [[ -f "$file" ]] || continue
                local bname="${file##*/}"
                bname="${bname%.md}"
                bname="${bname#[0-9][0-9]-[0-9][0-9]-[0-9][0-9]-}"
                echo "$bname"
            done
        fi
    }

    _get_ideas() {
        local jobs_dir="jobs/ideas"
        if [[ -d "$jobs_dir" ]]; then
            for file in "$jobs_dir"/*.md; do
                [[ -f "$file" ]] || continue
                local bname="${file##*/}"
                bname="${bname%.md}"
                bname="${bname#[0-9][0-9]-[0-9][0-9]-[0-9][0-9]-}"
                echo "$bname"
            done
        fi
    }

    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '1: :->command' \
        '*:: :->args'

    case $state in
        command)
            _describe 'command' commands
            ;;
        args)
            case $words[1] in
                list|ls)
                    if [[ $CURRENT -eq 2 ]]; then
                        _describe 'folder' folders
                    fi
                    ;;
                new)
                    if [[ $CURRENT -eq 2 ]]; then
                        _describe 'type' types
                    fi
                    ;;
                active|done)
                    if [[ $CURRENT -eq 2 ]]; then
                        local -a jobs
                        jobs=(${(f)"$(_get_jobs)"})
                        _describe 'job' jobs
                    fi
                    ;;
                promote)
                    if [[ $CURRENT -eq 2 ]]; then
                        local -a ideas
                        ideas=(${(f)"$(_get_ideas)"})
                        _describe 'idea' ideas
                    fi
                    ;;
                group)
                    if [[ $CURRENT -eq 2 ]]; then
                        local -a jobs
                        jobs=(${(f)"$(_get_jobs)"})
                        _describe 'job' jobs
                    fi
                    ;;
                ungroup)
                    if [[ $CURRENT -eq 2 ]]; then
                        local -a jobs
                        jobs=(${(f)"$(_get_jobs)"})
                        _describe 'job' jobs
                    fi
                    ;;
                move|mv)
                    if [[ $CURRENT -eq 2 ]]; then
                        _describe 'folder' folders
                    elif [[ $CURRENT -eq 3 ]]; then
                        local -a jobs
                        jobs=(${(f)"$(_get_jobs)"})
                        _describe 'job' jobs
                    fi
                    ;;
            esac
            ;;
    esac
}

compdef _j j
EOF
    exit 0
fi

# Fast git check - no subprocess
if [[ ! -d ".git" ]]; then
    echo "Error: Not in a git repository"
    exit 1
fi

JOBS_DIR="jobs"
FOLDERS=("planned" "active" "done" "ideas")

# Uppercase lookup using case (bash 3.2 compatible)
_uppercase_char() {
    case "$1" in
        a) REPLY=A;; b) REPLY=B;; c) REPLY=C;; d) REPLY=D;; e) REPLY=E;;
        f) REPLY=F;; g) REPLY=G;; h) REPLY=H;; i) REPLY=I;; j) REPLY=J;;
        k) REPLY=K;; l) REPLY=L;; m) REPLY=M;; n) REPLY=N;; o) REPLY=O;;
        p) REPLY=P;; q) REPLY=Q;; r) REPLY=R;; s) REPLY=S;; t) REPLY=T;;
        u) REPLY=U;; v) REPLY=V;; w) REPLY=W;; x) REPLY=X;; y) REPLY=Y;;
        z) REPLY=Z;; *) REPLY="$1";;
    esac
}

# Title case - pure bash, no subprocess
_title_case() {
    local input="$1" result="" word first rest
    for word in $input; do
        first="${word:0:1}"
        rest="${word:1}"
        _uppercase_char "$first"
        result+="$REPLY$rest "
    done
    REPLY="${result% }"
}

# Extract group from frontmatter - pure bash
_get_job_group() {
    local file="$1" started="" line
    REPLY=""
    [[ -f "$file" ]] || return
    while IFS= read -r line; do
        if [[ "$line" == "group:"* ]]; then
            local val="${line#group:}"
            val="${val#"${val%%[![:space:]]*}"}"
            REPLY="$val"
            return
        fi
        [[ "$line" == "---" && "$started" == "1" ]] && return
        [[ "$line" == "---" ]] && started=1
    done < "$file"
}

# Type emoji - no subprocess
_type_emoji() {
    case "$1" in
        ideas) REPLY="💡" ;;
        *) REPLY="✓" ;;
    esac
}

# Job type emoji
_job_type_emoji() {
    case "$1" in
        spec) REPLY="📋" ;;
        bug) REPLY="🐛" ;;
        idea) REPLY="💡" ;;
        *) REPLY="✓" ;;
    esac
}

# Ensure directories exist
_ensure_dirs() {
    for f in "${FOLDERS[@]}"; do
        [[ -d "$JOBS_DIR/$f" ]] || mkdir -p "$JOBS_DIR/$f"
    done
}

# Find job by fuzzy name match - optimized
_find_job() {
    local search="$1"
    local search_lower="${search,,}"  # bash 4+ lowercase, fallback below
    # Bash 3.2 fallback
    [[ -z "$search_lower" || "$search_lower" == "$search" ]] && search_lower=$(echo "$search" | tr '[:upper:]' '[:lower:]')

    local pattern="${search_lower//[-_ ]/*}"
    local best_match="" best_score=0

    for folder in "${FOLDERS[@]}"; do
        for file in "$JOBS_DIR/$folder"/*.md; do
            [[ -f "$file" ]] || continue
            local bname="${file##*/}"
            bname="${bname%.md}"
            local bname_lower="${bname,,}"
            [[ -z "$bname_lower" || "$bname_lower" == "$bname" ]] && bname_lower=$(echo "$bname" | tr '[:upper:]' '[:lower:]')

            if [[ "$bname_lower" == *"$pattern"* ]] || [[ "$bname_lower" =~ ${pattern//\*/.*} ]]; then
                local score=${#bname}
                if [[ $best_score -eq 0 ]] || [[ $score -lt $best_score ]]; then
                    best_match="$file"
                    best_score=$score
                fi
            fi
        done
    done
    REPLY="$best_match"
}

# List all jobs - optimized
list_jobs() {
    local filter_folder="$1"
    local filter_group="$2"
    _ensure_dirs

    # Validate filter
    if [[ -n "$filter_folder" ]]; then
        local valid=0
        for f in "${FOLDERS[@]}"; do
            [[ "$f" == "$filter_folder" ]] && valid=1 && break
        done
        if [[ $valid -eq 0 ]]; then
            echo "Error: Invalid folder '$filter_folder'. Must be one of: ${FOLDERS[*]}"
            exit 1
        fi
    fi

    if [[ -n "$filter_group" ]]; then
        echo "Jobs [group: $filter_group]"
    else
        echo "Jobs"
    fi
    echo ""

    for folder in "${FOLDERS[@]}"; do
        [[ -n "$filter_folder" && "$folder" != "$filter_folder" ]] && continue

        _type_emoji "$folder"
        local emoji="$REPLY"
        local has_items=0
        local output=""

        # Collect and sort files
        local files=""
        for item in "$JOBS_DIR/$folder"/*.md; do
            [[ -f "$item" ]] && files+="$item"$'\n'
        done
        [[ -z "$files" ]] && continue
        files=$(echo -n "$files" | sort -r)

        while IFS= read -r item; do
            [[ -z "$item" ]] && continue

            # Filter by group if specified
            if [[ -n "$filter_group" ]]; then
                _get_job_group "$item"
                [[ "$REPLY" != "$filter_group" ]] && continue
            fi

            has_items=1
            local bname="${item##*/}"
            bname="${bname%.md}"

            if [[ "$bname" =~ ^([0-9]{2})-([0-9]{2})-([0-9]{2})-(.+)$ ]]; then
                local day="${BASH_REMATCH[1]}"
                local month="${BASH_REMATCH[2]}"
                local year="${BASH_REMATCH[3]}"
                local name="${BASH_REMATCH[4]}"

                name="${name//-/ }"
                _title_case "$name"
                name="$REPLY"

                if [[ -z "$filter_group" ]]; then
                    _get_job_group "$item"
                    local job_group="$REPLY"
                    if [[ -n "$job_group" ]]; then
                        output+="  $emoji $name [$job_group] ($day/$month/$year)"$'\n'
                    else
                        output+="  $emoji $name ($day/$month/$year)"$'\n'
                    fi
                else
                    output+="  $emoji $name ($day/$month/$year)"$'\n'
                fi
            else
                output+="  $emoji $bname"$'\n'
            fi
        done <<< "$files"

        if [[ $has_items -eq 1 ]]; then
            echo "[$folder]"
            printf "%s" "$output"
            echo ""
        fi
    done
}

# Create new job
new_job() {
    local type="task"
    local folder="planned"
    local title=""
    local open_editor=0
    local group=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --spec|-s) type="spec"; shift ;;
            --bug|-b) type="bug"; shift ;;
            --idea|-i) type="idea"; folder="ideas"; shift ;;
            --task|-t) type="task"; shift ;;
            --active|-a) folder="active"; shift ;;
            --edit|-e) open_editor=1; shift ;;
            --group|-g) group="$2"; shift 2 ;;
            *) title="$*"; break ;;
        esac
    done

    if [[ -z "$title" ]]; then
        echo "Error: Title required"
        echo "Usage: j new [--spec|--bug|--idea] [--active] [--edit] <title>"
        exit 1
    fi

    _ensure_dirs

    local date_str=$(date +"%d-%m-%y")
    local slug="${title,,}"
    [[ -z "$slug" || "$slug" == "$title" ]] && slug=$(echo "$title" | tr '[:upper:]' '[:lower:]')
    slug="${slug//[^a-z0-9]/-}"
    slug="${slug//--/-}"
    slug="${slug#-}"
    slug="${slug%-}"

    local filename="$date_str-$slug.md"
    local filepath="$JOBS_DIR/$folder/$filename"

    if [[ -f "$filepath" ]]; then
        echo "Error: Job already exists: $filepath"
        exit 1
    fi

    local group_line=""
    [[ -n "$group" ]] && group_line="group: $group"

    local created_date=$(date +"%d %B %Y")

    case "$type" in
        spec)
            cat > "$filepath" <<EOF
---
type: spec${group_line:+
$group_line}
created: $created_date
---

# $title

## Overview

## Requirements

## Implementation

## Testing

EOF
            ;;
        bug)
            cat > "$filepath" <<EOF
---
type: bug${group_line:+
$group_line}
created: $created_date
---

# $title

## Description

## Steps to Reproduce

## Expected Behavior

EOF
            ;;
        idea)
            cat > "$filepath" <<EOF
---
type: idea${group_line:+
$group_line}
created: $created_date
---

# $title

## Concept

EOF
            ;;
        *)
            cat > "$filepath" <<EOF
---
type: task${group_line:+
$group_line}
created: $created_date
---

# $title

EOF
            ;;
    esac

    git add "$filepath"
    git commit -m "Add $type: $title"

    _job_type_emoji "$type"
    echo "$REPLY Created: $filepath"

    if [[ $open_editor -eq 1 && -n "$EDITOR" ]]; then
        $EDITOR "$filepath"
    fi
}

# Move job between folders
move_job() {
    local target_folder="$1"
    local name="$2"

    if [[ -z "$target_folder" || -z "$name" ]]; then
        echo "Error: Target folder and job name required"
        echo "Usage: j move <planned|active|done|ideas> <name>"
        exit 1
    fi

    local valid=0
    for f in "${FOLDERS[@]}"; do
        [[ "$f" == "$target_folder" ]] && valid=1 && break
    done

    if [[ $valid -eq 0 ]]; then
        echo "Error: Invalid folder '$target_folder'. Must be one of: ${FOLDERS[*]}"
        exit 1
    fi

    _find_job "$name"
    local job_file="$REPLY"

    if [[ -z "$job_file" ]]; then
        echo "Error: Job not found: $name"
        exit 1
    fi

    local filename="${job_file##*/}"
    local new_path="$JOBS_DIR/$target_folder/$filename"

    if [[ "$job_file" == "$new_path" ]]; then
        echo "Job already in $target_folder: $filename"
        exit 0
    fi

    if git ls-files --error-unmatch "$job_file" >/dev/null 2>&1; then
        git mv "$job_file" "$new_path"
        git commit -m "Move job '$name' to $target_folder"
        echo "Moved to $target_folder: $filename (git committed)"
    else
        mv "$job_file" "$new_path"
        echo "Moved to $target_folder: $filename"
    fi
}

# Show all groups
show_groups() {
    _ensure_dirs
    echo "Groups"
    echo ""

    local -a groups=()
    for folder in "${FOLDERS[@]}"; do
        for file in "$JOBS_DIR/$folder"/*.md; do
            [[ -f "$file" ]] || continue
            _get_job_group "$file"
            [[ -n "$REPLY" ]] && groups+=("$REPLY")
        done
    done

    if [[ ${#groups[@]} -eq 0 ]]; then
        echo "  No groups found"
        echo ""
        return
    fi

    local unique_groups=$(printf '%s\n' "${groups[@]}" | sort -u)

    while IFS= read -r g; do
        [[ -z "$g" ]] && continue
        local total=0 active=0

        for folder in "${FOLDERS[@]}"; do
            for file in "$JOBS_DIR/$folder"/*.md; do
                [[ -f "$file" ]] || continue
                _get_job_group "$file"
                if [[ "$REPLY" == "$g" ]]; then
                    ((total++))
                    [[ "$folder" == "active" ]] && ((active++))
                fi
            done
        done

        echo "  $g ($active active, $total total)"
    done <<< "$unique_groups"
    echo ""
}

# Assign job to group
assign_group() {
    local name="$1" group="$2"

    if [[ -z "$name" || -z "$group" ]]; then
        echo "Error: Job name and group required"
        echo "Usage: j group <name> <group>"
        exit 1
    fi

    _find_job "$name"
    local job_file="$REPLY"

    if [[ -z "$job_file" ]]; then
        echo "Error: Job not found: $name"
        exit 1
    fi

    # Update group in file
    if grep -q "^group:" "$job_file" 2>/dev/null; then
        sed -i '' "s/^group:.*$/group: $group/" "$job_file"
    else
        sed -i '' "/^type:/a\\
group: $group
" "$job_file"
    fi

    if git ls-files --error-unmatch "$job_file" >/dev/null 2>&1; then
        git add "$job_file"
        git commit -m "Assign job '$name' to group '$group'"
    fi

    local bname="${job_file##*/}"
    echo "Assigned: ${bname%.md} → $group"
}

# Remove job from group
remove_group() {
    local name="$1"

    if [[ -z "$name" ]]; then
        echo "Error: Job name required"
        echo "Usage: j ungroup <name>"
        exit 1
    fi

    _find_job "$name"
    local job_file="$REPLY"

    if [[ -z "$job_file" ]]; then
        echo "Error: Job not found: $name"
        exit 1
    fi

    _get_job_group "$job_file"
    local old_group="$REPLY"

    if [[ -z "$old_group" ]]; then
        local bname="${job_file##*/}"
        echo "Job has no group: ${bname%.md}"
        exit 0
    fi

    sed -i '' '/^group:/d' "$job_file"

    if git ls-files --error-unmatch "$job_file" >/dev/null 2>&1; then
        git add "$job_file"
        git commit -m "Remove job '$name' from group '$old_group'"
    fi

    local bname="${job_file##*/}"
    echo "Removed from group: ${bname%.md} (was: $old_group)"
}

# Promote idea to planned
promote_idea() {
    local name="$1"

    if [[ -z "$name" ]]; then
        echo "Error: Idea name required"
        echo "Usage: j promote <name>"
        exit 1
    fi

    local job_file=""
    local search_lower="${name,,}"
    [[ -z "$search_lower" || "$search_lower" == "$name" ]] && search_lower=$(echo "$name" | tr '[:upper:]' '[:lower:]')

    for file in "$JOBS_DIR/ideas"/*.md; do
        [[ -f "$file" ]] || continue
        local bname="${file##*/}"
        bname="${bname%.md}"
        local bname_lower="${bname,,}"
        [[ -z "$bname_lower" || "$bname_lower" == "$bname" ]] && bname_lower=$(echo "$bname" | tr '[:upper:]' '[:lower:]')

        if [[ "$bname_lower" == *"$search_lower"* ]]; then
            job_file="$file"
            break
        fi
    done

    if [[ -z "$job_file" ]]; then
        echo "Error: Idea not found: $name"
        exit 1
    fi

    local filename="${job_file##*/}"
    local new_path="$JOBS_DIR/planned/$filename"

    if git ls-files --error-unmatch "$job_file" >/dev/null 2>&1; then
        git mv "$job_file" "$new_path"
    else
        mv "$job_file" "$new_path"
    fi

    git add "$new_path"
    git commit -m "Promote idea '$name' to planned"

    echo "💡 Promoted to planned: $filename"
}

# Main
main() {
    local cmd="${1:-list}"

    case "$cmd" in
        list|ls|"")
            shift 2>/dev/null
            local folder="" group=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --group|-g) group="$2"; shift 2 ;;
                    *) folder="$1"; shift ;;
                esac
            done
            list_jobs "$folder" "$group"
            ;;
        new|create|add)
            shift
            new_job "$@"
            ;;
        active)
            shift
            move_job "active" "$*"
            ;;
        done)
            shift
            move_job "done" "$*"
            ;;
        promote)
            shift
            promote_idea "$1"
            ;;
        move|mv)
            shift
            move_job "$1" "$2"
            ;;
        groups)
            show_groups
            ;;
        group)
            shift
            assign_group "$1" "$2"
            ;;
        ungroup)
            shift
            remove_group "$1"
            ;;
        help|--help|-h)
            cat <<EOF
j - CLI tool for managing project jobs

Usage:
  j [list] [folder] [--group G]  List jobs (filter by folder and/or group)
  j new [options] <title>        Create new job
  j active <name>                Move job to active
  j done <name>                  Move job to done
  j promote <name>               Promote idea to planned
  j move <folder> <name>         Move job between folders
  j groups                       List all groups with counts
  j group <name> <group>         Assign job to a group
  j ungroup <name>               Remove job from its group
  j completion                   Output shell completion script

New job options:
  --spec, -s                     Create a spec
  --bug, -b                      Create a bug report
  --idea, -i                     Create an idea (goes to ideas/)
  --task, -t                     Create a task (default)
  --active, -a                   Start immediately in active/
  --group, -g <group>            Assign to group on creation
  --edit, -e                     Open in editor after creation

Types: task (default), spec, bug, idea
Folders: planned (default), active, done, ideas
Files: jobs/{folder}/dd-mm-yy-name.md

Setup:
  Add to ~/.zshrc:  eval "\$(j completion)"

Examples:
  j                              # List all jobs
  j list planned                 # List only planned
  j list --group bugfix          # List jobs in 'bugfix' group
  j groups                       # Show all groups with counts

  j new "fix login"              # Create task
  j new --group bugfix "fix x"   # Create task in group
  j new --bug "crash on mobile"  # Create bug
  j new --active "quick fix"     # Create and start now

  j active "fix login"           # Start working on job
  j done "fix login"             # Mark job complete

  j group "fix login" "sprint-1" # Assign existing job to group
  j ungroup "fix login"          # Remove job from group
EOF
            ;;
        *)
            echo "Error: Unknown command '$cmd'"
            echo "Run 'j help' for usage"
            exit 1
            ;;
    esac
}

main "$@"
