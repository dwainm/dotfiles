#!/usr/bin/env bash
# Git Worktree + Tmux Session Creator
# Creates a git worktree and corresponding tmux session with AI, editor, and shell windows

set -e

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Show usage
show_help() {
  cat << EOF
Usage: gwt [options] <new-branch-name>

Creates a git worktree in a sibling directory and sets up a tmux session with:
  - Window 1 "AI": Claude Code interactive CLI
  - Window 2 "shell": Terminal
  - Window 3 "nvim": nvim editor

Arguments:
  <new-branch-name>  The name of the new branch to create (required)

Options:
  -s                Interactive switcher - fuzzy find and switch between worktrees
  -l                List all git worktrees
  -d                Delete the worktree and tmux session for the specified branch
  -f                Force delete (skip unpushed commits check)
  -b <base-branch>  Create new branch FROM this base branch (e.g., gwt my-feature -b develop)
                    Default: auto-detect trunk/master/main
  -c                Create new branch FROM current branch
  -B                Checkout existing branch (local or remote, fetches if needed)
  -h, --help        Show this help message

Examples:
  gwt -s                        # Interactive worktree/session switcher
  gwt feature-name              # Create 'feature-name' from trunk/master/main
  gwt feature-name -b develop   # Create 'feature-name' from 'develop'
  gwt feature-name -c           # Create 'feature-name' from current branch
  gwt -B existing-branch        # Checkout existing local branch
  gwt -B feature/remote-branch  # Fetch and checkout remote branch
  gwt -d feature-name           # Delete worktree and tmux session

The worktree will be created at: ../<repo-name>-<branch-name>
The tmux session will be named: <repo-name>-<branch-name>
EOF
}

# Parse arguments
BRANCH_NAME=""
BASE_BRANCH=""
USE_CURRENT=false
DELETE_MODE=false
FORCE_DELETE=false
LIST_MODE=false
SWITCH_MODE=false
FORCE_EXISTING=false

while [[ $# -gt 0 ]]; do
  case $1 in
    -h|--help)
      show_help
      exit 0
      ;;
    -l)
      LIST_MODE=true
      shift
      ;;
    -s)
      SWITCH_MODE=true
      shift
      ;;
    -d)
      DELETE_MODE=true
      shift
      ;;
    -f)
      FORCE_DELETE=true
      shift
      ;;
    -b)
      BASE_BRANCH="$2"
      shift 2
      ;;
    -c)
      USE_CURRENT=true
      shift
      ;;
    -B)
      FORCE_EXISTING=true
      shift
      ;;
    -*)
      echo -e "${RED}Error: Unknown option $1${NC}"
      show_help
      exit 1
      ;;
    *)
      if [[ -z "$BRANCH_NAME" ]]; then
        BRANCH_NAME="$1"
      else
        echo -e "${RED}Error: Multiple branch names provided${NC}"
        show_help
        exit 1
      fi
      shift
      ;;
  esac
done

# Handle list mode
if [[ "$LIST_MODE" = true ]]; then
  # Check if we're in a git repository
  if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo -e "${RED}Error: Not in a git repository${NC}"
    exit 1
  fi

  echo -e "${BLUE}Git worktrees:${NC}"
  git worktree list
  exit 0
fi

# Handle switch mode - interactive worktree/session switcher
if [[ "$SWITCH_MODE" = true ]]; then
  # Check if we're in a git repository
  if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo -e "${RED}Error: Not in a git repository${NC}"
    exit 1
  fi

  # Check if fzf is installed
  if ! command -v fzf > /dev/null 2>&1; then
    echo -e "${RED}Error: fzf is required for switch mode${NC}"
    echo "Install with: brew install fzf"
    exit 1
  fi

  # Get current worktree path for marking
  CURRENT_PATH=$(git rev-parse --show-toplevel)

  # Get all worktrees with their branches
  # Format: path | branch
  worktrees=$(git worktree list --porcelain | awk '
    /^worktree / { path = substr($0, 10) }
    /^branch /   {
      branch = substr($0, 8)
      gsub(/refs\/heads\//, "", branch)
      print path "|" branch
    }
    /^HEAD /     {
      # Detached HEAD - use commit hash
      print path "|" substr($0, 6, 7) "(detached)"
    }
  ')

  # Check if we have any worktrees
  if [[ -z "$worktrees" ]]; then
    echo -e "${YELLOW}No worktrees found.${NC}"
    echo ""
    echo "Create one with: gwt <branch-name>"
    exit 0
  fi

  # Build display lines with session status
  display_lines=""
  while IFS='|' read -r path branch; do
    [[ -z "$path" ]] && continue
    session_name=$(basename "$path")

    # Check if tmux session exists
    if tmux has-session -t "$session_name" 2>/dev/null; then
      status="●"  # Session exists
    else
      status="○"  # No session
    fi

    # Mark current worktree
    if [[ "$path" == "$CURRENT_PATH" ]]; then
      marker="* "
    else
      marker="  "
    fi

    display_lines+="${marker}${status} ${branch}|${path}|${session_name}"$'\n'
  done <<< "$worktrees"

  # Remove trailing newline and run fzf
  selected=$(echo -n "$display_lines" | fzf \
    --header="enter=switch | alt-n=new branch | alt-k=delete worktree+session" \
    --delimiter='|' \
    --with-nth=1 \
    --preview='echo -e "\033[1;34mPath:\033[0m {2}" && echo "" && git -C {2} log --oneline -10 2>/dev/null && echo "" && echo -e "\033[1;34mRecent changes:\033[0m" && git -C {2} diff --stat HEAD~3..HEAD 2>/dev/null | tail -15' \
    --preview-window=right:40% \
    --expect=alt-n,alt-k)

  [[ -z "$selected" ]] && exit 0

  # Parse fzf output (first line is the key pressed, second is selection)
  key=$(echo "$selected" | head -1)
  selection=$(echo "$selected" | tail -1)

  [[ -z "$selection" ]] && exit 0

  # Extract path and session name
  path=$(echo "$selection" | cut -d'|' -f2)
  session_name=$(echo "$selection" | cut -d'|' -f3)
  branch_name=$(basename "$path" | sed "s/^[^-]*-//")

  case "$key" in
    alt-k)
      # Delete worktree and session
      echo -e "${YELLOW}Deleting worktree: $path${NC}"
      gwt -d "$branch_name"
      echo -e "${GREEN}Done. Press any key to continue...${NC}"
      read -n 1
      exec gwt -s  # Re-run switcher
      ;;
    alt-n)
      # Create new branch off the highlighted worktree
      echo -e "${BLUE}New branch name (branching from $branch_name):${NC}"
      read -r new_branch
      if [[ -n "$new_branch" ]]; then
        cd "$path" && gwt "$new_branch" -c
      fi
      ;;
    *)
      # Default: switch or create session
      if tmux has-session -t "$session_name" 2>/dev/null; then
        tmux switch-client -t "$session_name"
      else
        # Create new session in that worktree (same setup as gwt create)
        tmux new-session -d -s "$session_name" -n "AI" -c "$path"

        # Set up AI window
        if command -v claude > /dev/null 2>&1; then
          tmux send-keys -t "$session_name:AI" "cc" C-m
        fi

        # Create shell window
        tmux new-window -t "$session_name" -n "shell" -c "$path"

        # Create nvim window
        tmux new-window -t "$session_name" -n "nvim" -c "$path"
        if command -v nvim > /dev/null 2>&1; then
          tmux send-keys -t "$session_name:nvim" "nvim" C-m
        fi

        # Select first window and switch
        tmux select-window -t "$session_name:AI"
        tmux switch-client -t "$session_name"
      fi
      ;;
  esac

  exit 0
fi

# Validate branch name provided
if [[ -z "$BRANCH_NAME" ]]; then
  echo -e "${RED}Error: Branch name required${NC}"
  show_help
  exit 1
fi

# Check if we're in a git repository
if ! git rev-parse --git-dir > /dev/null 2>&1; then
  echo -e "${RED}Error: Not in a git repository${NC}"
  exit 1
fi

# Get current repo root and name (needed for both create and delete)
REPO_ROOT=$(git rev-parse --show-toplevel)
REPO_NAME=$(basename "$REPO_ROOT")
WORKTREE_NAME="${REPO_NAME}-${BRANCH_NAME}"
WORKTREE_PATH="$(cd "$REPO_ROOT/.." && pwd)/${WORKTREE_NAME}"

# Handle delete mode
if [[ "$DELETE_MODE" = true ]]; then
  DELETED_SOMETHING=false

  # Check for unpushed commits (unless force delete)
  if [[ "$FORCE_DELETE" = false ]]; then
    # Check if branch exists and has upstream
    if git show-ref --verify --quiet "refs/heads/$BRANCH_NAME"; then
      UPSTREAM=$(git for-each-ref --format='%(upstream:short)' "refs/heads/$BRANCH_NAME")
      if [[ -n "$UPSTREAM" ]]; then
        # Check for unpushed commits
        UNPUSHED=$(git log --oneline "$UPSTREAM..$BRANCH_NAME" 2>/dev/null)
        if [[ -n "$UNPUSHED" ]]; then
          echo -e "${RED}Error: Branch '${BRANCH_NAME}' has unpushed commits:${NC}"
          echo "$UNPUSHED"
          echo -e "${YELLOW}Use -f to force delete${NC}"
          exit 1
        fi
      else
        # No upstream, check if branch has any commits not in main branches
        for main in trunk master main; do
          if git show-ref --verify --quiet "refs/heads/$main"; then
            UNPUSHED=$(git log --oneline "$main..$BRANCH_NAME" 2>/dev/null)
            if [[ -n "$UNPUSHED" ]]; then
              echo -e "${RED}Error: Branch '${BRANCH_NAME}' has commits not in ${main}:${NC}"
              echo "$UNPUSHED"
              echo -e "${YELLOW}Use -f to force delete${NC}"
              exit 1
            fi
            break
          fi
        done
      fi
    fi
  fi

  # Kill tmux session if it exists
  if tmux has-session -t "$WORKTREE_NAME" 2>/dev/null; then
    echo -e "${YELLOW}Killing tmux session: ${WORKTREE_NAME}${NC}"
    tmux kill-session -t "$WORKTREE_NAME"
    echo -e "${GREEN}✓ Tmux session deleted${NC}"
    DELETED_SOMETHING=true
  else
    echo -e "${BLUE}No tmux session found: ${WORKTREE_NAME}${NC}"
  fi

  # Remove git worktree if it exists
  if git worktree list | grep -q "$WORKTREE_PATH"; then
    echo -e "${YELLOW}Removing worktree: ${WORKTREE_PATH}${NC}"
    git worktree remove "$WORKTREE_PATH" 2>/dev/null || git worktree remove --force "$WORKTREE_PATH"
    echo -e "${GREEN}✓ Worktree removed${NC}"
    DELETED_SOMETHING=true
  else
    echo -e "${BLUE}No worktree found: ${WORKTREE_PATH}${NC}"
  fi

  if [[ "$DELETED_SOMETHING" = false ]]; then
    echo -e "${YELLOW}Nothing to delete${NC}"
    exit 1
  fi

  exit 0
fi

# Check if tmux is installed (only needed for create mode)
if ! command -v tmux > /dev/null 2>&1; then
  echo -e "${RED}Error: tmux is not installed${NC}"
  echo "Install with: brew install tmux"
  exit 1
fi

# Check if claude is installed
if ! command -v claude > /dev/null 2>&1; then
  echo -e "${YELLOW}Warning: claude CLI not found. Install from https://code.claude.ai${NC}"
fi

# Handle existing branch mode
if [[ "$FORCE_EXISTING" = true ]]; then
  # Check if branch exists locally
  if git show-ref --verify --quiet "refs/heads/$BRANCH_NAME"; then
    echo -e "${BLUE}Checking out existing local branch: ${BRANCH_NAME}${NC}"
  # Check if branch exists on a remote
  elif git show-ref --verify --quiet "refs/remotes/origin/$BRANCH_NAME"; then
    echo -e "${BLUE}Fetching remote branch: origin/${BRANCH_NAME}${NC}"
    git fetch origin "$BRANCH_NAME"
    REMOTE_BRANCH="origin/$BRANCH_NAME"
  else
    # Try other remotes
    REMOTE_BRANCH=$(git branch -r --list "*/$BRANCH_NAME" | head -1 | xargs)
    if [[ -n "$REMOTE_BRANCH" ]]; then
      REMOTE_NAME=$(echo "$REMOTE_BRANCH" | cut -d'/' -f1)
      echo -e "${BLUE}Fetching remote branch: ${REMOTE_BRANCH}${NC}"
      git fetch "$REMOTE_NAME" "$BRANCH_NAME"
    else
      echo -e "${RED}Error: Branch '${BRANCH_NAME}' does not exist locally or on any remote${NC}"
      echo "Use 'gwt $BRANCH_NAME' without -B to create a new branch"
      exit 1
    fi
  fi
else
  # Determine base branch for new branch creation
  if [[ "$USE_CURRENT" = true ]]; then
    BASE_BRANCH=$(git branch --show-current)
    if [[ -z "$BASE_BRANCH" ]]; then
      echo -e "${RED}Error: Not on a branch (detached HEAD)${NC}"
      exit 1
    fi
    echo -e "${BLUE}Branching off current branch: ${BASE_BRANCH}${NC}"
  elif [[ -z "$BASE_BRANCH" ]]; then
    # Auto-detect main branch
    if git show-ref --verify --quiet refs/heads/trunk; then
      BASE_BRANCH="trunk"
    elif git show-ref --verify --quiet refs/heads/master; then
      BASE_BRANCH="master"
    elif git show-ref --verify --quiet refs/heads/main; then
      BASE_BRANCH="main"
    else
      echo -e "${RED}Error: Could not detect main branch (tried trunk, master, main)${NC}"
      echo "Use -b to specify a base branch or -c to use current branch"
      exit 1
    fi
    echo -e "${BLUE}Auto-detected base branch: ${BASE_BRANCH}${NC}"
  else
    # Verify specified base branch exists (check both local and remote)
    if ! git show-ref --verify --quiet "refs/heads/$BASE_BRANCH" && \
       ! git show-ref --verify --quiet "refs/remotes/$BASE_BRANCH"; then
      echo -e "${RED}Error: Base branch '${BASE_BRANCH}' does not exist${NC}"
      exit 1
    fi
    echo -e "${BLUE}Using base branch: ${BASE_BRANCH}${NC}"
  fi
fi

# Check if worktree already exists
if [[ -d "$WORKTREE_PATH" ]]; then
  echo -e "${RED}Error: Worktree directory already exists: ${WORKTREE_PATH}${NC}"
  exit 1
fi

# Check if tmux session already exists
if tmux has-session -t "$WORKTREE_NAME" 2>/dev/null; then
  echo -e "${YELLOW}Warning: tmux session '${WORKTREE_NAME}' already exists${NC}"
  echo -e "${BLUE}Attaching to existing session...${NC}"
  tmux attach-session -t "$WORKTREE_NAME"
  exit 0
fi

# Create git worktree
echo -e "${GREEN}Creating worktree: ${WORKTREE_PATH}${NC}"
if [[ "$FORCE_EXISTING" = true ]]; then
  if [[ -n "$REMOTE_BRANCH" ]]; then
    # Create local branch tracking the remote
    git worktree add --track -b "$BRANCH_NAME" "$WORKTREE_PATH" "$REMOTE_BRANCH"
  else
    # Checkout existing local branch
    git worktree add "$WORKTREE_PATH" "$BRANCH_NAME"
  fi
else
  # Create new branch
  git worktree add -b "$BRANCH_NAME" "$WORKTREE_PATH" "$BASE_BRANCH"
fi

# Handle Rails database symlinking
if [[ -f "$WORKTREE_PATH/bin/rails" ]]; then
  echo -e "${BLUE}Rails project detected${NC}"

  # Check if main repo has a storage directory
  if [[ -d "$REPO_ROOT/storage" ]]; then
    # Remove the newly created storage directory if it exists
    if [[ -d "$WORKTREE_PATH/storage" ]]; then
      echo -e "${YELLOW}Removing worktree storage directory${NC}"
      rm -rf "$WORKTREE_PATH/storage"
    fi

    # Copy storage from main repo
    echo -e "${GREEN}Copying storage from main repo (independent database)${NC}"
    cp -r "$REPO_ROOT/storage" "$WORKTREE_PATH/storage"
    echo -e "${GREEN}✓ Database copied to worktree${NC}"
  else
    echo -e "${YELLOW}Note: Main repo has no storage directory yet${NC}"
    echo -e "${YELLOW}Storage will be created independently in this worktree${NC}"
  fi

  # Remove .dev-port file so a fresh one is created when dev is run
  if [[ -f "$WORKTREE_PATH/.dev-port" ]]; then
    rm "$WORKTREE_PATH/.dev-port"
    echo -e "${GREEN}✓ Removed .dev-port (fresh ports will be assigned)${NC}"
  fi

  # Copy Rails credentials keys (these are gitignored but needed for development)
  if [[ -d "$REPO_ROOT/config/credentials" ]]; then
    echo -e "${BLUE}Copying Rails credentials keys${NC}"
    mkdir -p "$WORKTREE_PATH/config/credentials"

    # Copy development key if it exists
    if [[ -f "$REPO_ROOT/config/credentials/development.key" ]]; then
      cp "$REPO_ROOT/config/credentials/development.key" "$WORKTREE_PATH/config/credentials/development.key"
      echo -e "${GREEN}✓ development.key copied${NC}"
    fi

    # Copy production key if it exists
    if [[ -f "$REPO_ROOT/config/credentials/production.key" ]]; then
      cp "$REPO_ROOT/config/credentials/production.key" "$WORKTREE_PATH/config/credentials/production.key"
      echo -e "${GREEN}✓ production.key copied${NC}"
    fi

    # Copy master key if it exists (for credentials.yml.enc)
    if [[ -f "$REPO_ROOT/config/master.key" ]]; then
      cp "$REPO_ROOT/config/master.key" "$WORKTREE_PATH/config/master.key"
      echo -e "${GREEN}✓ master.key copied${NC}"
    fi
  fi
fi

# Handle CLAUDE-DEV.md -> CLAUDE.md setup
if [[ -f "$REPO_ROOT/CLAUDE-DEV.md" ]]; then
  echo -e "${BLUE}Setting up dev CLAUDE.md in worktree${NC}"
  cp "$REPO_ROOT/CLAUDE-DEV.md" "$WORKTREE_PATH/CLAUDE.md"
  cd "$WORKTREE_PATH"
  git update-index --skip-worktree CLAUDE.md
  cd "$REPO_ROOT"
  echo -e "${GREEN}✓ CLAUDE.md configured for dev work${NC}"
fi

# Create tmux session (detached)
echo -e "${GREEN}Creating tmux session: ${WORKTREE_NAME}${NC}"

# Create session with first window
tmux new-session -d -s "$WORKTREE_NAME" -n "AI" -c "$WORKTREE_PATH"

# Set up first window (AI) - use cc alias for dangerously-skip-permissions
if command -v claude > /dev/null 2>&1; then
  tmux send-keys -t "$WORKTREE_NAME:AI" "cc" C-m
else
  tmux send-keys -t "$WORKTREE_NAME:AI" "echo 'Claude CLI not installed. Install from https://code.claude.ai'" C-m
fi

# Create second window (shell)
tmux new-window -t "$WORKTREE_NAME" -n "shell" -c "$WORKTREE_PATH"

# Create third window (nvim)
tmux new-window -t "$WORKTREE_NAME" -n "nvim" -c "$WORKTREE_PATH"
if command -v nvim > /dev/null 2>&1; then
  tmux send-keys -t "$WORKTREE_NAME:nvim" "nvim" C-m
else
  tmux send-keys -t "$WORKTREE_NAME:nvim" "echo 'nvim not installed'" C-m
fi

# Select first window
tmux select-window -t "$WORKTREE_NAME:AI"

echo -e "${GREEN}✓ Worktree created at: ${WORKTREE_PATH}${NC}"
echo -e "${GREEN}✓ Tmux session created: ${WORKTREE_NAME}${NC}"
echo -e "${BLUE}To attach: tmux attach -t ${WORKTREE_NAME}${NC}"
echo -e "${BLUE}To list sessions: tmux ls${NC}"
