#!/usr/bin/env bash
# Git Worktree + Tmux Window Creator
# Simple: gwt <branch-name> ["<purpose>"]

set -e

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

show_help() {
  cat << EOF
Usage: gwt [options] <branch-name> [purpose]

Creates git worktree + tmux window. Purpose sets PURPOSE env var.

Options:
  gwt <branch> [purpose]    Create worktree
  gwt -i "<instruction>"    Smart mode: use AI to determine branch & purpose
  gwt -l                    List worktrees
  gwt -s                    List gwt-created tmux windows/sessions
  gwt -d <branch>           Delete worktree
  gwt -b <base> <branch>    Create from base branch
  gwt -c <branch>           Create from current branch
  gwt -B <branch>           Checkout existing branch

Examples:
  gwt feature "Add auth #42"
  gwt -i "fix login bug from issue #42"
  gwt hotfix
  gwt -d feature
EOF
}

BRANCH_NAME=""
PURPOSE=""
BASE_BRANCH=""
USE_CURRENT=false
DELETE_MODE=false
LIST_MODE=false
SHOW_MODE=false
CHECKOUT_EXISTING=false
INSTRUCTION_MODE=false
INSTRUCTION=""

while [[ $# -gt 0 ]]; do
  case $1 in
    -h|--help) show_help; exit 0 ;;
    -l) LIST_MODE=true; shift ;;
    -s) SHOW_MODE=true; shift ;;
    -d) DELETE_MODE=true; shift ;;
    -b) BASE_BRANCH="$2"; shift 2 ;;
    -c) USE_CURRENT=true; shift ;;
    -B) CHECKOUT_EXISTING=true; shift ;;
    -i)
      INSTRUCTION_MODE=true
      INSTRUCTION="$2"
      shift 2
      ;;
    -*)
      echo -e "${RED}Unknown: $1${NC}" >&2
      exit 1
      ;;
    *)
      if [[ -z "$BRANCH_NAME" ]]; then
        BRANCH_NAME="$1"
      elif [[ -z "$PURPOSE" ]]; then
        PURPOSE="$1"
      else
        echo -e "${RED}Too many args${NC}" >&2
        exit 1
      fi
      shift
      ;;
  esac
done

# Show gwt-created tmux windows/sessions (no git repo needed)
if [[ "$SHOW_MODE" = true ]]; then
  echo -e "${BLUE}GWT Windows/Sessions:${NC}"
  echo ""
  found=0
  while IFS=: read -r sess win_idx win_name branch; do
    if [[ -n "$branch" ]]; then
      echo -e "  ${GREEN}$sess${NC}:${win_idx} ${win_name}  (branch: $branch)"
      found=1
    fi
  done < <(tmux list-windows -a -F "#{session_name}:#{window_index}:#{window_name}:#{@gwt-branch}" 2>/dev/null)
  if [[ "$found" -eq 0 ]]; then
    echo "  No gwt-created windows found."
    echo ""
    echo "  Create one with: gwt <branch-name>"
  fi
  echo ""
  echo "Press Enter to close..."
  read
  exit 0
fi

git rev-parse --git-dir > /dev/null 2>&1 || {
  echo -e "${RED}Not a git repo${NC}" >&2
  exit 1
}

REPO_ROOT=$(git rev-parse --show-toplevel)
MAIN_REPO_ROOT=$(git worktree list --porcelain 2>/dev/null | awk '/^worktree / {print $2; exit}')
[[ -z "$MAIN_REPO_ROOT" ]] && MAIN_REPO_ROOT="$REPO_ROOT"
REPO_NAME=$(basename "$MAIN_REPO_ROOT")
SAFE_NAME=$(echo "$REPO_NAME" | sed 's/\./_/g')

# Instruction mode - call AI to figure out branch and purpose
if [[ "$INSTRUCTION_MODE" = true ]]; then
  echo -e "${BLUE}Interpret: $INSTRUCTION${NC}"
  
  GWT_MODEL="opencode/minimax-m2.5-free"
  echo -e "${BLUE}Model: $GWT_MODEL${NC}"
  
  # Detect issue number vs free-text instruction
  TMPFILE=$(mktemp /tmp/gwt-output.XXXXXX.json)
  AI_PROMPT=""
  if [[ "$INSTRUCTION" =~ ^[0-9]+$ ]]; then
    # ── Issue mode: fetch context via gh ──
    ISSUE_NUM="$INSTRUCTION"
    echo -e "${BLUE}Fetching issue #$ISSUE_NUM...${NC}"
    
    if ! command -v gh &>/dev/null; then
      echo -e "${RED}gh CLI not found. Install: brew install gh${NC}" >&2
      exit 1
    fi
    
    ISSUE_JSON=$(gh issue view "$ISSUE_NUM" --json number,title,body,labels,state 2>/dev/null)
    if [[ -z "$ISSUE_JSON" ]]; then
      echo -e "${RED}Failed to fetch issue #$ISSUE_NUM${NC}" >&2
      exit 1
    fi
    
    ISSUE_TITLE=$(echo "$ISSUE_JSON" | python3 -c "import sys,json; print(json.load(sys.stdin)['title'])" 2>/dev/null)
    ISSUE_BODY=$(echo "$ISSUE_JSON" | python3 -c "import sys,json; print(json.load(sys.stdin)['body'][:300])" 2>/dev/null)
    ISSUE_LABELS=$(echo "$ISSUE_JSON" | python3 -c "import sys,json; print(', '.join(l['name'] for l in json.load(sys.stdin).get('labels',[])))" 2>/dev/null)
    ISSUE_STATE=$(echo "$ISSUE_JSON" | python3 -c "import sys,json; print(json.load(sys.stdin)['state'])" 2>/dev/null)
    
    echo -e "${BLUE}#$ISSUE_NUM [$ISSUE_STATE] $ISSUE_TITLE${NC}"
    [[ -n "$ISSUE_LABELS" ]] && echo -e "${BLUE}Labels: $ISSUE_LABELS${NC}"
    
    AI_PROMPT="GitHub Issue #$ISSUE_NUM: $ISSUE_TITLE
Labels: $ISSUE_LABELS
State: $ISSUE_STATE
Body: $ISSUE_BODY

Write this exact JSON to $TMPFILE (nothing else in the file):
{\"branch\": \"kebab-case-branch\", \"purpose\": \"brief purpose from issue title\"}
Use labels to determine branch prefix (bug→fix/, feature→feat/, etc). Only write the JSON."
  else
    # ── Text mode: use instruction as-is ──
    AI_PROMPT="Instruction: $INSTRUCTION

Write this exact JSON to $TMPFILE (nothing else in the file):
{\"branch\": \"kebab-case-branch\", \"purpose\": \"brief summary of the task\"}
Only write the JSON."
  fi
  
  timeout 30 opencode run --pure --model "$GWT_MODEL" "$AI_PROMPT" 2>/dev/null
  
  if [[ -f "$TMPFILE" && -s "$TMPFILE" ]]; then
    BRANCH_NAME=$(python3 -c "import json; print(json.load(open('$TMPFILE')).get('branch',''))" 2>/dev/null)
    PURPOSE=$(python3 -c "import json; print(json.load(open('$TMPFILE')).get('purpose',''))" 2>/dev/null)
    rm -f "$TMPFILE"
  else
    rm -f "$TMPFILE"
    BRANCH_NAME=""
    PURPOSE=""
  fi
  
  if [[ -z "$BRANCH_NAME" ]]; then
    echo -e "${RED}Failed to get branch name from AI${NC}" >&2
    exit 1
  fi
  
  echo -e "${GREEN}Branch: $BRANCH_NAME${NC}"
  echo -e "${GREEN}Purpose: $PURPOSE${NC}"
fi

# Compute safe name for worktree directory paths (replace / with -)
SAFE_NAME=$(echo "$BRANCH_NAME" | tr '/' '-')

# List
if [[ "$LIST_MODE" = true ]]; then
  git worktree list
  exit 0
fi

# Delete
if [[ "$DELETE_MODE" = true ]]; then
[[ -z "$BRANCH_NAME" ]] && { echo -e "${RED}Need branch name${NC}" >&2; exit 1; }
  
  # Find worktree by branch (try direct match, then strip repo prefix)
  ACTUAL_BRANCH="$BRANCH_NAME"
  WORKTREE_PATH=""
  while IFS= read -r wt_path _branch; do
    _branch="${_branch##refs/heads/}"
    if [[ "$_branch" = "$BRANCH_NAME" ]]; then
      WORKTREE_PATH="$wt_path"
      break
    fi
  done < <(git worktree list --porcelain 2>/dev/null | awk '/^worktree /{wt=$2} /^branch /{print wt" "$2}')
  
  # Try stripping REPO_NAME prefix if not found
  if [[ -z "$WORKTREE_PATH" && "$BRANCH_NAME" = "${REPO_NAME}-"* ]]; then
    ACTUAL_BRANCH="${BRANCH_NAME#${REPO_NAME}-}"
    while IFS= read -r wt_path _branch; do
      _branch="${_branch##refs/heads/}"
      if [[ "$_branch" = "$ACTUAL_BRANCH" ]]; then
        WORKTREE_PATH="$wt_path"
        break
      fi
    done < <(git worktree list --porcelain 2>/dev/null | awk '/^worktree /{wt=$2} /^branch /{print wt" "$2}')
  fi
  
  if [[ -z "$WORKTREE_PATH" ]]; then
    echo -e "${RED}Worktree not found for: $BRANCH_NAME${NC}" >&2
    exit 1
  fi
  
  # 1. Kill tmux window/session (match by gwt-branch option or fallback to name)
  FOUND=$(tmux list-windows -a -F "#{window_id}:#{session_name}:#{@gwt-branch}:#{window_name}" 2>/dev/null | grep ":${ACTUAL_BRANCH}:" | head -1)
  if [[ -z "$FOUND" ]]; then
    FOUND=$(tmux list-windows -a -F "#{window_id}:#{session_name}:#{window_name}" 2>/dev/null | grep "${ACTUAL_BRANCH}" | head -1)
  fi
  if [[ -n "$FOUND" ]]; then
    WIN_ID=$(echo "$FOUND" | cut -d: -f1)
    SESS=$(echo "$FOUND" | cut -d: -f2)
    echo -e "${YELLOW}Kill window: $SESS:$WIN_ID${NC}"
    tmux kill-window -t "$WIN_ID" 2>/dev/null || true
  fi
  
  # 2. Remove worktree
  if git worktree list | grep -q "$WORKTREE_PATH"; then
    echo -e "${YELLOW}Remove worktree: $WORKTREE_PATH${NC}"
    git worktree remove "$WORKTREE_PATH" 2>/dev/null || \
      git worktree remove --force "$WORKTREE_PATH" 2>/dev/null || true
  fi
  
  # 3. Delete local branch
  if git show-ref --verify --quiet "refs/heads/$ACTUAL_BRANCH" 2>/dev/null; then
    echo -e "${YELLOW}Delete branch: $ACTUAL_BRANCH${NC}"
    git branch -D "$ACTUAL_BRANCH" 2>/dev/null || true
  fi
  
  # 4. Remove directory if it still exists
  if [[ -d "$WORKTREE_PATH" ]]; then
    echo -e "${YELLOW}Remove directory: $WORKTREE_PATH${NC}"
    rm -rf "$WORKTREE_PATH" 2>/dev/null || true
  fi
  
  echo -e "${GREEN}✓ Cleanup complete${NC}"
  exit 0
fi

# Create mode
[[ -z "$BRANCH_NAME" ]] && { echo -e "${RED}Need branch name${NC}" >&2; show_help; exit 1; }

# Detect base branch
if [[ "$USE_CURRENT" = true ]]; then
  BASE_BRANCH=$(git branch --show-current)
elif [[ -z "$BASE_BRANCH" ]]; then
  for b in main trunk master; do
    git show-ref --verify --quiet refs/heads/$b 2>/dev/null && { BASE_BRANCH=$b; break; }
  done
fi
[[ -z "$BASE_BRANCH" ]] && { echo -e "${RED}No base branch${NC}" >&2; exit 1; }

WORKTREE_PATH="$(cd "$REPO_ROOT/.." && pwd)/${REPO_NAME}-${SAFE_NAME}"
[[ -d "$WORKTREE_PATH" ]] && { echo -e "${RED}Exists: $WORKTREE_PATH${NC}" >&2; exit 1; }

# Create worktree
echo -e "${BLUE}From: $BASE_BRANCH${NC}"
echo -e "${GREEN}Create: $WORKTREE_PATH${NC}"

if [[ "$CHECKOUT_EXISTING" = true ]]; then
  if git show-ref --verify --quiet "refs/heads/$BRANCH_NAME" 2>/dev/null; then
    git worktree add "$WORKTREE_PATH" "$BRANCH_NAME"
  elif git show-ref --verify --quiet "refs/remotes/origin/$BRANCH_NAME" 2>/dev/null; then
    git worktree add --track -b "$BRANCH_NAME" "$WORKTREE_PATH" "origin/$BRANCH_NAME"
  else
    echo -e "${RED}Branch not found: $BRANCH_NAME${NC}" >&2
    exit 1
  fi
else
  git worktree add -b "$BRANCH_NAME" "$WORKTREE_PATH" "$BASE_BRANCH"
fi

# Rails setup
if [[ -f "$WORKTREE_PATH/bin/rails" ]]; then
  echo -e "${BLUE}Rails setup${NC}"
  [[ -d "$REPO_ROOT/storage" ]] && {
    rm -rf "$WORKTREE_PATH/storage"
    cp -r "$REPO_ROOT/storage" "$WORKTREE_PATH/storage"
    echo -e "${GREEN}✓ DB copied${NC}"
  }
  [[ -f "$WORKTREE_PATH/.dev-port" ]] && rm "$WORKTREE_PATH/.dev-port"
fi

# Create window/session
WINDOW_NAME="${BRANCH_NAME}"

echo -e "${GREEN}Window: $WINDOW_NAME${NC}"

if [[ -n "$TMUX" ]]; then
  # Inside tmux: create a new window in current session
  WINDOW_ID=$(tmux new-window -d -P -F "#{window_id}" -n "$WINDOW_NAME" -c "$WORKTREE_PATH" -e "PURPOSE=${PURPOSE}")
  
  # Store branch name for gwt -d
  tmux set-window-option -t "$WINDOW_ID" gwt-branch "$BRANCH_NAME" 2>/dev/null || true
  
  # Start opencode with prompt pre-loaded
  if [[ -n "$PURPOSE" ]]; then
    tmux send-keys -t "$WINDOW_ID" "opencode --prompt \"$PURPOSE\"" C-m
  else
    tmux send-keys -t "$WINDOW_ID" "opencode" C-m
  fi
  
else
  # Not in tmux: create a new session
  SESSION_ID=$(tmux new-session -d -P -F "#{session_id}" -s "$WINDOW_NAME" -c "$WORKTREE_PATH" -e "PURPOSE=${PURPOSE}")
  
  tmux set-window-option -t "$SESSION_ID" gwt-branch "$BRANCH_NAME" 2>/dev/null || true
  
  if [[ -n "$PURPOSE" ]]; then
    tmux send-keys -t "$SESSION_ID" "opencode --prompt \"$PURPOSE\"" C-m
  else
    tmux send-keys -t "$SESSION_ID" "opencode" C-m
  fi
  
  echo -e "${BLUE}Attach: tmux attach -t '$WINDOW_NAME'${NC}"
fi

echo -e "${GREEN}✓ Done${NC}"
