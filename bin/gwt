#!/usr/bin/env bash
# Git Worktree + Tmux Window Creator
# Simple: gwt <branch-name> ["<purpose>"]

set -e

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

show_help() {
  cat << EOF
Usage: gwt [options] <branch-name> [purpose]

Creates git worktree + tmux window. Purpose sets PURPOSE env var.

Options:
  gwt <branch> [purpose]    Create worktree
  gwt -i "<instruction>"    Smart mode: use AI to determine branch & purpose
  gwt -l                    List worktrees
  gwt -d <branch>           Delete worktree
  gwt -b <base> <branch>    Create from base branch
  gwt -c <branch>           Create from current branch
  gwt -B <branch>           Checkout existing branch

Examples:
  gwt feature "Add auth #42"
  gwt -i "fix login bug from issue #42"
  gwt hotfix
  gwt -d feature
EOF
}

BRANCH_NAME=""
PURPOSE=""
BASE_BRANCH=""
USE_CURRENT=false
DELETE_MODE=false
LIST_MODE=false
CHECKOUT_EXISTING=false
INSTRUCTION_MODE=false
INSTRUCTION=""

while [[ $# -gt 0 ]]; do
  case $1 in
    -h|--help) show_help; exit 0 ;;
    -l) LIST_MODE=true; shift ;;
    -d) DELETE_MODE=true; shift ;;
    -b) BASE_BRANCH="$2"; shift 2 ;;
    -c) USE_CURRENT=true; shift ;;
    -B) CHECKOUT_EXISTING=true; shift ;;
    -i)
      INSTRUCTION_MODE=true
      INSTRUCTION="$2"
      shift 2
      ;;
    -*)
      echo -e "${RED}Unknown: $1${NC}" >&2
      exit 1
      ;;
    *)
      if [[ -z "$BRANCH_NAME" ]]; then
        BRANCH_NAME="$1"
      elif [[ -z "$PURPOSE" ]]; then
        PURPOSE="$1"
      else
        echo -e "${RED}Too many args${NC}" >&2
        exit 1
      fi
      shift
      ;;
  esac
done

git rev-parse --git-dir > /dev/null 2>&1 || {
  echo -e "${RED}Not a git repo${NC}" >&2
  exit 1
}

REPO_ROOT=$(git rev-parse --show-toplevel)
REPO_NAME=$(basename "$REPO_ROOT")
SAFE_NAME=$(echo "$REPO_NAME" | sed 's/\./_/g')

# Instruction mode - call opencode to figure out branch and purpose
if [[ "$INSTRUCTION_MODE" = true ]]; then
  echo -e "${BLUE}Interpret: $INSTRUCTION${NC}"
  
  GWT_MODEL="opencode-go/kimi-k2.6"
  echo -e "${BLUE}Model: $GWT_MODEL${NC}"
  
  # Use opencode with a one-shot prompt to get branch and purpose
  RESPONSE=$(timeout 30 opencode run --model "$GWT_MODEL" "Given this instruction: \"$INSTRUCTION\", respond with ONLY this format (no other text):
BRANCH: <kebab-case-branch-name>
PURPOSE: <human readable purpose>" 2>/dev/null | tail -10)
  
  # Parse the response
  BRANCH_NAME=$(echo "$RESPONSE" | grep "^BRANCH:" | sed 's/^BRANCH: *//' | tr -d '\n')
  PURPOSE=$(echo "$RESPONSE" | grep "^PURPOSE:" | sed 's/^PURPOSE: *//' | tr -d '\n')
  
  if [[ -z "$BRANCH_NAME" ]]; then
    echo -e "${RED}Failed to parse branch from opencode response${NC}" >&2
    echo "$RESPONSE" >&2
    exit 1
  fi
  
  echo -e "${GREEN}Branch: $BRANCH_NAME${NC}"
  echo -e "${GREEN}Purpose: $PURPOSE${NC}"
fi

# List
if [[ "$LIST_MODE" = true ]]; then
  git worktree list
  exit 0
fi

# Delete
if [[ "$DELETE_MODE" = true ]]; then
  [[ -z "$BRANCH_NAME" ]] && { echo -e "${RED}Need branch name${NC}" >&2; exit 1; }
  
  WORKTREE_PATH="$(cd "$REPO_ROOT/.." && pwd)/${REPO_NAME}-${BRANCH_NAME}"
  
  # 1. Kill tmux window/session (match by gwt-branch option or fallback to name)
  FOUND=$(tmux list-windows -a -F "#{window_id}:#{session_name}:#{@gwt-branch}:#{window_name}" 2>/dev/null | grep ":${BRANCH_NAME}:" | head -1)
  if [[ -z "$FOUND" ]]; then
    FOUND=$(tmux list-windows -a -F "#{window_id}:#{session_name}:#{window_name}" 2>/dev/null | grep "${BRANCH_NAME}" | head -1)
  fi
  if [[ -n "$FOUND" ]]; then
    WIN_ID=$(echo "$FOUND" | cut -d: -f1)
    SESS=$(echo "$FOUND" | cut -d: -f2)
    echo -e "${YELLOW}Kill window: $SESS:$WIN_ID${NC}"
    tmux kill-window -t "$WIN_ID" 2>/dev/null || true
  fi
  
  # 2. Remove worktree
  if git worktree list | grep -q "$WORKTREE_PATH"; then
    echo -e "${YELLOW}Remove worktree: $WORKTREE_PATH${NC}"
    git worktree remove "$WORKTREE_PATH" 2>/dev/null || \
      git worktree remove --force "$WORKTREE_PATH" 2>/dev/null || true
  fi
  
  # 3. Delete local branch (NEW - was missing!)
  if git show-ref --verify --quiet "refs/heads/$BRANCH_NAME" 2>/dev/null; then
    echo -e "${YELLOW}Delete branch: $BRANCH_NAME${NC}"
    git branch -D "$BRANCH_NAME" 2>/dev/null || true
  fi
  
  # 4. Remove directory if it still exists (NEW - was missing!)
  if [[ -d "$WORKTREE_PATH" ]]; then
    echo -e "${YELLOW}Remove directory: $WORKTREE_PATH${NC}"
    rm -rf "$WORKTREE_PATH" 2>/dev/null || true
  fi
  
  echo -e "${GREEN}✓ Cleanup complete${NC}"
  exit 0
fi

# Create mode
[[ -z "$BRANCH_NAME" ]] && { echo -e "${RED}Need branch name${NC}" >&2; show_help; exit 1; }

# Detect base branch
if [[ "$USE_CURRENT" = true ]]; then
  BASE_BRANCH=$(git branch --show-current)
elif [[ -z "$BASE_BRANCH" ]]; then
  for b in main trunk master; do
    git show-ref --verify --quiet refs/heads/$b 2>/dev/null && { BASE_BRANCH=$b; break; }
  done
fi
[[ -z "$BASE_BRANCH" ]] && { echo -e "${RED}No base branch${NC}" >&2; exit 1; }

WORKTREE_PATH="$(cd "$REPO_ROOT/.." && pwd)/${REPO_NAME}-${BRANCH_NAME}"
[[ -d "$WORKTREE_PATH" ]] && { echo -e "${RED}Exists: $WORKTREE_PATH${NC}" >&2; exit 1; }

# Create worktree
echo -e "${BLUE}From: $BASE_BRANCH${NC}"
echo -e "${GREEN}Create: $WORKTREE_PATH${NC}"

if [[ "$CHECKOUT_EXISTING" = true ]]; then
  if git show-ref --verify --quiet "refs/heads/$BRANCH_NAME" 2>/dev/null; then
    git worktree add "$WORKTREE_PATH" "$BRANCH_NAME"
  elif git show-ref --verify --quiet "refs/remotes/origin/$BRANCH_NAME" 2>/dev/null; then
    git worktree add --track -b "$BRANCH_NAME" "$WORKTREE_PATH" "origin/$BRANCH_NAME"
  else
    echo -e "${RED}Branch not found: $BRANCH_NAME${NC}" >&2
    exit 1
  fi
else
  git worktree add -b "$BRANCH_NAME" "$WORKTREE_PATH" "$BASE_BRANCH"
fi

# Rails setup
if [[ -f "$WORKTREE_PATH/bin/rails" ]]; then
  echo -e "${BLUE}Rails setup${NC}"
  [[ -d "$REPO_ROOT/storage" ]] && {
    rm -rf "$WORKTREE_PATH/storage"
    cp -r "$REPO_ROOT/storage" "$WORKTREE_PATH/storage"
    echo -e "${GREEN}✓ DB copied${NC}"
  }
  [[ -f "$WORKTREE_PATH/.dev-port" ]] && rm "$WORKTREE_PATH/.dev-port"
fi

# Create window/session
WINDOW_NAME="${BRANCH_NAME}"

echo -e "${GREEN}Window: $WINDOW_NAME${NC}"

if [[ -n "$TMUX" ]]; then
  # Inside tmux: create a new window in current session
  WINDOW_ID=$(tmux new-window -d -P -F "#{window_id}" -n "$WINDOW_NAME" -c "$WORKTREE_PATH" -e "PURPOSE=${PURPOSE}")
  
  # Store branch name for gwt -d
  tmux set-window-option -t "$WINDOW_ID" gwt-branch "$BRANCH_NAME" 2>/dev/null || true
  
  # Start opencode with prompt pre-loaded
  if [[ -n "$PURPOSE" ]]; then
    tmux send-keys -t "$WINDOW_ID" "opencode --prompt \"$PURPOSE\"" C-m
  else
    tmux send-keys -t "$WINDOW_ID" "opencode" C-m
  fi
  
  # Switch to the new window
  tmux select-window -t "$WINDOW_ID"
else
  # Not in tmux: create a new session
  SESSION_ID=$(tmux new-session -d -P -F "#{session_id}" -s "$WINDOW_NAME" -c "$WORKTREE_PATH" -e "PURPOSE=${PURPOSE}")
  
  tmux set-window-option -t "$SESSION_ID" gwt-branch "$BRANCH_NAME" 2>/dev/null || true
  
  if [[ -n "$PURPOSE" ]]; then
    tmux send-keys -t "$SESSION_ID" "opencode --prompt \"$PURPOSE\"" C-m
  else
    tmux send-keys -t "$SESSION_ID" "opencode" C-m
  fi
  
  tmux attach-session -t "$SESSION_ID"
fi

echo -e "${GREEN}✓ Done${NC}"
